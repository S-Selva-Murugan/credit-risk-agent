{
  "annotations": { "list": [] },
  "description": "Token consumption and analysis metrics for the CreditIQ AI Agent",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Token Consumption per Agent (Input vs Output)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "options": {
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "xTickLabelRotation": -45
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "displayName": "${__series.name}" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "increase(credit_tokens_total{token_type=\"input\"}[5m])",
          "legendFormat": "Input – {{agent}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "increase(credit_tokens_total{token_type=\"output\"}[5m])",
          "legendFormat": "Output – {{agent}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "Token Rate & Analysis Volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [{ "id": "custom.axisPlacement", "value": "right" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "rate(credit_tokens_total[5m]) * 300",
          "legendFormat": "Tokens/5m – {{agent}} ({{token_type}})",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "rate(credit_analyses_total[5m]) * 300",
          "legendFormat": "Analyses/5m",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Analysis Latency (avg + p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "rate(credit_analysis_duration_seconds_sum[5m]) / rate(credit_analysis_duration_seconds_count[5m])",
          "legendFormat": "avg latency",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "histogram_quantile(0.95, rate(credit_analysis_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Risk Level Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "options": {
        "pieType": "pie",
        "displayLabels": ["name", "percent"]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "credit_risk_level_total",
          "legendFormat": "{{risk_level}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Request Throughput",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "rate(credit_requests_total[5m])",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total Tokens (session cumulative)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(credit_tokens_total{token_type=\"input\"})",
          "legendFormat": "Input tokens",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(credit_tokens_total{token_type=\"output\"})",
          "legendFormat": "Output tokens",
          "refId": "B",
          "instant": true
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["credit-risk", "ai-agent", "tokens"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "CreditIQ AI Agent — Token & Analysis Metrics",
  "uid": "creditiq-agent-v1",
  "version": 1
}
